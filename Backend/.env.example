# Backend environment example — copy to .env and fill for production
# ⚠️ SECURITY: Do NOT commit your real credentials to git
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Server
PORT=5000
NODE_ENV=development

# MongoDB — use MongoDB Atlas for production
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/cricx?retryWrites=true&w=majority

# JWT — Use a long random string (min 32 chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_secure_random_string_at_least_32_chars

# CORS — Frontend domain for production
FRONTEND_ORIGIN=https://your-frontend-domain.com

# Rate limiting (requests per minute)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Error tracking service (e.g., Sentry)
# SENTRY_DSN=https://key@sentry.io/project
